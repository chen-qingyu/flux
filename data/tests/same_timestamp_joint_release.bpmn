<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
    xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
    id="Definitions_Same_Timestamp_Joint_Release"
    targetNamespace="http://bpmn.io/schema/bpmn">
    <bpmn:process id="Process_same_timestamp_joint_release" name="同刻同时释放 oldest feasible" isExecutable="true">
        <bpmn:startEvent id="Event_start_hold_r1" name="占用R1发生器">
            <bpmn:extensionElements>
                <camunda:properties>
                    <camunda:property name="_initiatorType" value="random" />
                    <camunda:property name="_distributionType" value="static" />
                    <camunda:property name="_entityCount" value="1" />
                    <camunda:property name="_entityType" value="hold_r1" />
                    <camunda:property name="_staticInterval" value="1" />
                </camunda:properties>
            </bpmn:extensionElements>
            <bpmn:outgoing>Flow_hold_r1_start_to_task</bpmn:outgoing>
        </bpmn:startEvent>
        <bpmn:startEvent id="Event_start_hold_r2" name="占用R2发生器">
            <bpmn:extensionElements>
                <camunda:properties>
                    <camunda:property name="_initiatorType" value="random" />
                    <camunda:property name="_distributionType" value="static" />
                    <camunda:property name="_entityCount" value="1" />
                    <camunda:property name="_entityType" value="hold_r2" />
                    <camunda:property name="_staticInterval" value="1" />
                </camunda:properties>
            </bpmn:extensionElements>
            <bpmn:outgoing>Flow_hold_r2_start_to_task</bpmn:outgoing>
        </bpmn:startEvent>
        <bpmn:startEvent id="Event_start_wait_all" name="等待全部资源发生器">
            <bpmn:extensionElements>
                <camunda:properties>
                    <camunda:property name="_initiatorType" value="random" />
                    <camunda:property name="_distributionType" value="static" />
                    <camunda:property name="_entityCount" value="1" />
                    <camunda:property name="_entityType" value="all_case" />
                    <camunda:property name="_staticInterval" value="1" />
                </camunda:properties>
            </bpmn:extensionElements>
            <bpmn:outgoing>Flow_wait_all_start_to_delay</bpmn:outgoing>
        </bpmn:startEvent>
        <bpmn:startEvent id="Event_start_wait_r1" name="等待R1发生器">
            <bpmn:extensionElements>
                <camunda:properties>
                    <camunda:property name="_initiatorType" value="random" />
                    <camunda:property name="_distributionType" value="static" />
                    <camunda:property name="_entityCount" value="1" />
                    <camunda:property name="_entityType" value="r1_case" />
                    <camunda:property name="_staticInterval" value="1" />
                </camunda:properties>
            </bpmn:extensionElements>
            <bpmn:outgoing>Flow_wait_r1_start_to_delay</bpmn:outgoing>
        </bpmn:startEvent>

        <bpmn:task id="Task_hold_r1" name="占用R1任务">
            <bpmn:extensionElements>
                <camunda:properties>
                    <camunda:property name="_taskType" value="delay" />
                    <camunda:property name="_resourceStrategy" value="all" />
                    <camunda:property name="_distributionType" value="static" />
                    <camunda:property name="_staticInterval" value="4" />
                </camunda:properties>
            </bpmn:extensionElements>
            <bpmn:incoming>Flow_hold_r1_start_to_task</bpmn:incoming>
            <bpmn:outgoing>Flow_hold_r1_task_to_end</bpmn:outgoing>
        </bpmn:task>
        <bpmn:task id="Task_hold_r2" name="占用R2任务">
            <bpmn:extensionElements>
                <camunda:properties>
                    <camunda:property name="_taskType" value="delay" />
                    <camunda:property name="_resourceStrategy" value="all" />
                    <camunda:property name="_distributionType" value="static" />
                    <camunda:property name="_staticInterval" value="4" />
                </camunda:properties>
            </bpmn:extensionElements>
            <bpmn:incoming>Flow_hold_r2_start_to_task</bpmn:incoming>
            <bpmn:outgoing>Flow_hold_r2_task_to_end</bpmn:outgoing>
        </bpmn:task>
        <bpmn:task id="Task_delay_all" name="延迟到达全部资源任务">
            <bpmn:extensionElements>
                <camunda:properties>
                    <camunda:property name="_taskType" value="delay" />
                    <camunda:property name="_distributionType" value="static" />
                    <camunda:property name="_staticInterval" value="1" />
                </camunda:properties>
            </bpmn:extensionElements>
            <bpmn:incoming>Flow_wait_all_start_to_delay</bpmn:incoming>
            <bpmn:outgoing>Flow_delay_all_to_need_all</bpmn:outgoing>
        </bpmn:task>
        <bpmn:task id="Task_need_all" name="需要全部资源任务">
            <bpmn:extensionElements>
                <camunda:properties>
                    <camunda:property name="_taskType" value="delay" />
                    <camunda:property name="_resourceStrategy" value="all" />
                    <camunda:property name="_distributionType" value="static" />
                    <camunda:property name="_staticInterval" value="1" />
                </camunda:properties>
            </bpmn:extensionElements>
            <bpmn:incoming>Flow_delay_all_to_need_all</bpmn:incoming>
            <bpmn:outgoing>Flow_need_all_to_end</bpmn:outgoing>
        </bpmn:task>
        <bpmn:task id="Task_delay_r1" name="延迟到达R1任务">
            <bpmn:extensionElements>
                <camunda:properties>
                    <camunda:property name="_taskType" value="delay" />
                    <camunda:property name="_distributionType" value="static" />
                    <camunda:property name="_staticInterval" value="2" />
                </camunda:properties>
            </bpmn:extensionElements>
            <bpmn:incoming>Flow_wait_r1_start_to_delay</bpmn:incoming>
            <bpmn:outgoing>Flow_delay_r1_to_need_r1</bpmn:outgoing>
        </bpmn:task>
        <bpmn:task id="Task_need_r1" name="只需要R1任务">
            <bpmn:extensionElements>
                <camunda:properties>
                    <camunda:property name="_taskType" value="delay" />
                    <camunda:property name="_resourceStrategy" value="all" />
                    <camunda:property name="_distributionType" value="static" />
                    <camunda:property name="_staticInterval" value="1" />
                </camunda:properties>
            </bpmn:extensionElements>
            <bpmn:incoming>Flow_delay_r1_to_need_r1</bpmn:incoming>
            <bpmn:outgoing>Flow_need_r1_to_end</bpmn:outgoing>
        </bpmn:task>

        <bpmn:dataStoreReference id="DataStoreReference_r1" name="R1">
            <bpmn:extensionElements>
                <camunda:properties>
                    <camunda:property name="_resourceType" value="resource" />
                    <camunda:property name="_capacity" value="1" />
                </camunda:properties>
            </bpmn:extensionElements>
        </bpmn:dataStoreReference>
        <bpmn:dataStoreReference id="DataStoreReference_r2" name="R2">
            <bpmn:extensionElements>
                <camunda:properties>
                    <camunda:property name="_resourceType" value="resource" />
                    <camunda:property name="_capacity" value="1" />
                </camunda:properties>
            </bpmn:extensionElements>
        </bpmn:dataStoreReference>

        <bpmn:endEvent id="Event_end_hold_r1" name="占用R1结束">
            <bpmn:incoming>Flow_hold_r1_task_to_end</bpmn:incoming>
        </bpmn:endEvent>
        <bpmn:endEvent id="Event_end_hold_r2" name="占用R2结束">
            <bpmn:incoming>Flow_hold_r2_task_to_end</bpmn:incoming>
        </bpmn:endEvent>
        <bpmn:endEvent id="Event_end_need_all" name="全部资源结束">
            <bpmn:incoming>Flow_need_all_to_end</bpmn:incoming>
        </bpmn:endEvent>
        <bpmn:endEvent id="Event_end_need_r1" name="R1结束">
            <bpmn:incoming>Flow_need_r1_to_end</bpmn:incoming>
        </bpmn:endEvent>

        <bpmn:sequenceFlow id="Flow_hold_r1_start_to_task" sourceRef="Event_start_hold_r1" targetRef="Task_hold_r1" />
        <bpmn:sequenceFlow id="Flow_hold_r1_task_to_end" sourceRef="Task_hold_r1" targetRef="Event_end_hold_r1" />
        <bpmn:sequenceFlow id="Flow_hold_r2_start_to_task" sourceRef="Event_start_hold_r2" targetRef="Task_hold_r2" />
        <bpmn:sequenceFlow id="Flow_hold_r2_task_to_end" sourceRef="Task_hold_r2" targetRef="Event_end_hold_r2" />
        <bpmn:sequenceFlow id="Flow_wait_all_start_to_delay" sourceRef="Event_start_wait_all" targetRef="Task_delay_all" />
        <bpmn:sequenceFlow id="Flow_delay_all_to_need_all" sourceRef="Task_delay_all" targetRef="Task_need_all" />
        <bpmn:sequenceFlow id="Flow_need_all_to_end" sourceRef="Task_need_all" targetRef="Event_end_need_all" />
        <bpmn:sequenceFlow id="Flow_wait_r1_start_to_delay" sourceRef="Event_start_wait_r1" targetRef="Task_delay_r1" />
        <bpmn:sequenceFlow id="Flow_delay_r1_to_need_r1" sourceRef="Task_delay_r1" targetRef="Task_need_r1" />
        <bpmn:sequenceFlow id="Flow_need_r1_to_end" sourceRef="Task_need_r1" targetRef="Event_end_need_r1" />

        <bpmn:association id="Association_hold_r1" associationDirection="Both" sourceRef="Task_hold_r1" targetRef="DataStoreReference_r1" />
        <bpmn:association id="Association_hold_r2" associationDirection="Both" sourceRef="Task_hold_r2" targetRef="DataStoreReference_r2" />
        <bpmn:association id="Association_need_all_r1" associationDirection="Both" sourceRef="Task_need_all" targetRef="DataStoreReference_r1" />
        <bpmn:association id="Association_need_all_r2" associationDirection="Both" sourceRef="Task_need_all" targetRef="DataStoreReference_r2" />
        <bpmn:association id="Association_need_r1" associationDirection="Both" sourceRef="Task_need_r1" targetRef="DataStoreReference_r1" />
    </bpmn:process>
</bpmn:definitions>