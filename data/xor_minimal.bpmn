<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
    xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
    id="Definitions_Xor_Minimal"
    targetNamespace="http://bpmn.io/schema/bpmn">
    <bpmn:process id="Process_xor_minimal" name="XOR 最小流程" isExecutable="true">
        <bpmn:startEvent id="Event_start" name="XOR发生器">
            <bpmn:extensionElements>
                <camunda:properties>
                    <camunda:property name="_initiatorType" value="static" />
                    <camunda:property name="_entityCount" value="1" />
                    <camunda:property name="_entityType" value="case" />
                    <camunda:property name="_staticInterval" value="1" />
                </camunda:properties>
            </bpmn:extensionElements>
            <bpmn:outgoing>Flow_start_to_xor</bpmn:outgoing>
        </bpmn:startEvent>
        <bpmn:exclusiveGateway id="Gateway_xor" name="互斥决策">
            <bpmn:incoming>Flow_start_to_xor</bpmn:incoming>
            <bpmn:outgoing>Flow_xor_to_a</bpmn:outgoing>
            <bpmn:outgoing>Flow_xor_to_b</bpmn:outgoing>
        </bpmn:exclusiveGateway>
        <bpmn:task id="Task_a" name="路径A任务">
            <bpmn:extensionElements>
                <camunda:properties>
                    <camunda:property name="_taskType" value="delay" />
                    <camunda:property name="_distributionType" value="static" />
                    <camunda:property name="_staticInterval" value="5" />
                </camunda:properties>
            </bpmn:extensionElements>
            <bpmn:incoming>Flow_xor_to_a</bpmn:incoming>
            <bpmn:outgoing>Flow_a_to_end</bpmn:outgoing>
        </bpmn:task>
        <bpmn:task id="Task_b" name="路径B任务">
            <bpmn:extensionElements>
                <camunda:properties>
                    <camunda:property name="_taskType" value="delay" />
                    <camunda:property name="_distributionType" value="static" />
                    <camunda:property name="_staticInterval" value="9" />
                </camunda:properties>
            </bpmn:extensionElements>
            <bpmn:incoming>Flow_xor_to_b</bpmn:incoming>
            <bpmn:outgoing>Flow_b_to_end</bpmn:outgoing>
        </bpmn:task>
        <bpmn:endEvent id="Event_end" name="结束">
            <bpmn:incoming>Flow_a_to_end</bpmn:incoming>
            <bpmn:incoming>Flow_b_to_end</bpmn:incoming>
        </bpmn:endEvent>
        <bpmn:sequenceFlow id="Flow_start_to_xor" sourceRef="Event_start" targetRef="Gateway_xor" />
        <bpmn:sequenceFlow id="Flow_xor_to_a" sourceRef="Gateway_xor" targetRef="Task_a" />
        <bpmn:sequenceFlow id="Flow_xor_to_b" sourceRef="Gateway_xor" targetRef="Task_b" />
        <bpmn:sequenceFlow id="Flow_a_to_end" sourceRef="Task_a" targetRef="Event_end" />
        <bpmn:sequenceFlow id="Flow_b_to_end" sourceRef="Task_b" targetRef="Event_end" />
    </bpmn:process>
</bpmn:definitions>