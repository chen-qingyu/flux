<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
    xmlns:camunda="http://camunda.org/schema/1.0/bpmn" id="Definitions_Lifecycle" targetNamespace="http://bpmn.io/schema/bpmn">
    <bpmn:process id="Process_lifecycle" name="资源生命周期综合流程" isExecutable="true">
        <bpmn:startEvent id="Event_start_subset" name="子集释放发生器">
            <bpmn:extensionElements>
                <camunda:properties>
                    <camunda:property name="_initiatorType" value="random" />
                    <camunda:property name="_distributionType" value="static" />
                    <camunda:property name="_entityCount" value="1" />
                    <camunda:property name="_entityType" value="subset_case" />
                    <camunda:property name="_staticInterval" value="1" />
                </camunda:properties>
            </bpmn:extensionElements>
            <bpmn:outgoing>Flow_subset_start_to_acquire</bpmn:outgoing>
        </bpmn:startEvent>
        <bpmn:startEvent id="Event_start_all" name="全部释放发生器">
            <bpmn:extensionElements>
                <camunda:properties>
                    <camunda:property name="_initiatorType" value="random" />
                    <camunda:property name="_distributionType" value="static" />
                    <camunda:property name="_entityCount" value="1" />
                    <camunda:property name="_entityType" value="all_case" />
                    <camunda:property name="_staticInterval" value="1" />
                </camunda:properties>
            </bpmn:extensionElements>
            <bpmn:outgoing>Flow_all_start_to_delay</bpmn:outgoing>
        </bpmn:startEvent>

        <bpmn:task id="Task_acquire_subset" name="获取两种资源">
            <bpmn:extensionElements>
                <camunda:properties>
                    <camunda:property name="_taskType" value="acquireResource" />
                    <camunda:property name="_resourceStrategy" value="all" />
                </camunda:properties>
            </bpmn:extensionElements>
            <bpmn:incoming>Flow_subset_start_to_acquire</bpmn:incoming>
            <bpmn:outgoing>Flow_subset_acquire_to_hold</bpmn:outgoing>
        </bpmn:task>
        <bpmn:task id="Task_hold_subset" name="持有两种资源">
            <bpmn:extensionElements>
                <camunda:properties>
                    <camunda:property name="_taskType" value="delay" />
                    <camunda:property name="_distributionType" value="static" />
                    <camunda:property name="_staticInterval" value="3" />
                </camunda:properties>
            </bpmn:extensionElements>
            <bpmn:incoming>Flow_subset_acquire_to_hold</bpmn:incoming>
            <bpmn:outgoing>Flow_subset_hold_to_release_bound</bpmn:outgoing>
        </bpmn:task>
        <bpmn:task id="Task_release_bound" name="只释放叉车">
            <bpmn:extensionElements>
                <camunda:properties>
                    <camunda:property name="_taskType" value="releaseResource" />
                </camunda:properties>
            </bpmn:extensionElements>
            <bpmn:incoming>Flow_subset_hold_to_release_bound</bpmn:incoming>
            <bpmn:outgoing>Flow_release_bound_to_hold_driver</bpmn:outgoing>
        </bpmn:task>
        <bpmn:task id="Task_hold_driver" name="继续持有司机">
            <bpmn:extensionElements>
                <camunda:properties>
                    <camunda:property name="_taskType" value="delay" />
                    <camunda:property name="_distributionType" value="static" />
                    <camunda:property name="_staticInterval" value="2" />
                </camunda:properties>
            </bpmn:extensionElements>
            <bpmn:incoming>Flow_release_bound_to_hold_driver</bpmn:incoming>
            <bpmn:outgoing>Flow_hold_driver_to_release_all_remaining</bpmn:outgoing>
        </bpmn:task>
        <bpmn:task id="Task_release_all_remaining" name="释放剩余资源">
            <bpmn:extensionElements>
                <camunda:properties>
                    <camunda:property name="_taskType" value="releaseResource" />
                </camunda:properties>
            </bpmn:extensionElements>
            <bpmn:incoming>Flow_hold_driver_to_release_all_remaining</bpmn:incoming>
            <bpmn:outgoing>Flow_release_all_remaining_to_end</bpmn:outgoing>
        </bpmn:task>

        <bpmn:task id="Task_delay_all_arrival" name="延迟到达全部释放">
            <bpmn:extensionElements>
                <camunda:properties>
                    <camunda:property name="_taskType" value="delay" />
                    <camunda:property name="_distributionType" value="static" />
                    <camunda:property name="_staticInterval" value="10" />
                </camunda:properties>
            </bpmn:extensionElements>
            <bpmn:incoming>Flow_all_start_to_delay</bpmn:incoming>
            <bpmn:outgoing>Flow_all_delay_to_acquire</bpmn:outgoing>
        </bpmn:task>

        <bpmn:task id="Task_acquire_all" name="再次获取两种资源">
            <bpmn:extensionElements>
                <camunda:properties>
                    <camunda:property name="_taskType" value="acquireResource" />
                    <camunda:property name="_resourceStrategy" value="all" />
                </camunda:properties>
            </bpmn:extensionElements>
            <bpmn:incoming>Flow_all_delay_to_acquire</bpmn:incoming>
            <bpmn:outgoing>Flow_all_acquire_to_hold</bpmn:outgoing>
        </bpmn:task>
        <bpmn:task id="Task_hold_all" name="再次持有两种资源">
            <bpmn:extensionElements>
                <camunda:properties>
                    <camunda:property name="_taskType" value="delay" />
                    <camunda:property name="_distributionType" value="static" />
                    <camunda:property name="_staticInterval" value="3" />
                </camunda:properties>
            </bpmn:extensionElements>
            <bpmn:incoming>Flow_all_acquire_to_hold</bpmn:incoming>
            <bpmn:outgoing>Flow_all_hold_to_release</bpmn:outgoing>
        </bpmn:task>
        <bpmn:task id="Task_release_all" name="释放全部资源">
            <bpmn:extensionElements>
                <camunda:properties>
                    <camunda:property name="_taskType" value="releaseResource" />
                </camunda:properties>
            </bpmn:extensionElements>
            <bpmn:incoming>Flow_all_hold_to_release</bpmn:incoming>
            <bpmn:outgoing>Flow_release_all_to_end</bpmn:outgoing>
        </bpmn:task>

        <bpmn:dataStoreReference id="DataStoreReference_forklift" name="叉车">
            <bpmn:extensionElements>
                <camunda:properties>
                    <camunda:property name="_resourceType" value="resource" />
                    <camunda:property name="_capacity" value="1" />
                </camunda:properties>
            </bpmn:extensionElements>
        </bpmn:dataStoreReference>
        <bpmn:dataStoreReference id="DataStoreReference_driver" name="司机">
            <bpmn:extensionElements>
                <camunda:properties>
                    <camunda:property name="_resourceType" value="resource" />
                    <camunda:property name="_capacity" value="1" />
                </camunda:properties>
            </bpmn:extensionElements>
        </bpmn:dataStoreReference>

        <bpmn:endEvent id="Event_end_subset" name="子集释放结束">
            <bpmn:incoming>Flow_release_all_remaining_to_end</bpmn:incoming>
        </bpmn:endEvent>
        <bpmn:endEvent id="Event_end_all" name="全部释放结束">
            <bpmn:incoming>Flow_release_all_to_end</bpmn:incoming>
        </bpmn:endEvent>

        <bpmn:sequenceFlow id="Flow_subset_start_to_acquire" sourceRef="Event_start_subset" targetRef="Task_acquire_subset" />
        <bpmn:sequenceFlow id="Flow_subset_acquire_to_hold" sourceRef="Task_acquire_subset" targetRef="Task_hold_subset" />
        <bpmn:sequenceFlow id="Flow_subset_hold_to_release_bound" sourceRef="Task_hold_subset" targetRef="Task_release_bound" />
        <bpmn:sequenceFlow id="Flow_release_bound_to_hold_driver" sourceRef="Task_release_bound" targetRef="Task_hold_driver" />
        <bpmn:sequenceFlow id="Flow_hold_driver_to_release_all_remaining" sourceRef="Task_hold_driver" targetRef="Task_release_all_remaining" />
        <bpmn:sequenceFlow id="Flow_release_all_remaining_to_end" sourceRef="Task_release_all_remaining" targetRef="Event_end_subset" />
        <bpmn:sequenceFlow id="Flow_all_start_to_delay" sourceRef="Event_start_all" targetRef="Task_delay_all_arrival" />
        <bpmn:sequenceFlow id="Flow_all_delay_to_acquire" sourceRef="Task_delay_all_arrival" targetRef="Task_acquire_all" />
        <bpmn:sequenceFlow id="Flow_all_acquire_to_hold" sourceRef="Task_acquire_all" targetRef="Task_hold_all" />
        <bpmn:sequenceFlow id="Flow_all_hold_to_release" sourceRef="Task_hold_all" targetRef="Task_release_all" />
        <bpmn:sequenceFlow id="Flow_release_all_to_end" sourceRef="Task_release_all" targetRef="Event_end_all" />

        <bpmn:association id="Association_acquire_subset_forklift" associationDirection="Both" sourceRef="Task_acquire_subset" targetRef="DataStoreReference_forklift" />
        <bpmn:association id="Association_acquire_subset_driver" associationDirection="Both" sourceRef="Task_acquire_subset" targetRef="DataStoreReference_driver" />
        <bpmn:association id="Association_release_bound_forklift" associationDirection="Both" sourceRef="Task_release_bound" targetRef="DataStoreReference_forklift" />
        <bpmn:association id="Association_acquire_all_forklift" associationDirection="Both" sourceRef="Task_acquire_all" targetRef="DataStoreReference_forklift" />
        <bpmn:association id="Association_acquire_all_driver" associationDirection="Both" sourceRef="Task_acquire_all" targetRef="DataStoreReference_driver" />
    </bpmn:process>
</bpmn:definitions>